{
  "bot-name": "CypherX",
  "description": "CypherX, your friendly assistant!",
  "logo": "https://camo.githubusercontent.com/d78794cd6ff2ce53602eb0b2c433df2a60eb95e2b13580eb745a8a89e1acc1ed/68747470733a2f2f692e6962622e636f2f6e717352634b44422f58706c6f61646572342e6a7067",
  "repository": "https://github.com/Dark-Xploit/CypherX",
  "documentation-link": "https://pair.cypherxbot.space",
  "stack": "container",

  "formation": {
    "web": {
      "quantity": 1,
      "size": "standard-1x"
    }
  },

  "addons": [
    { "plan": "heroku-postgresql" }
  ],

  "scripts": {
    "start": "node index.js"
  },

  "env": {
    "SESSION_ID": {
      "description": "Must begin with 'XPLOADER-BOT:~' or 'CYPHER-X:~'.",
      "required": false
    }
  },

  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" },
    { "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git" }
  ]
}
